# GodSpeaks — Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env itself.

# Required: Google Gemini API key (paid tier — image generation model requires billing)
GEMINI_API_KEY=your_gemini_api_key_here

# Required for production SEO: canonical URL, OG tags, sitemap, robots.txt
# Set to your actual domain once deployed (e.g. https://godspeaks.com)
NEXT_PUBLIC_SITE_URL=https://godspeaks.com

# SCRIPTURE_API_KEY is no longer needed.
# Bible EN (KJV) and Bible FR (Louis Segond) now use ibibles.net — no auth required.
